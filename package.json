		"@types/node": "^25.7.0",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.33.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vite-multiple-assets": "^2.2.6"
	},
